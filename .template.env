# ── Security (universally required) ──────────────────────────────────────────
SECRETS_ENCRYPTION_KEY=                 # long random string, used in auth + GitHub token handling

# ── GitHub App (required for web/GitHub App flow) ────────────────────────────
GITHUB_APP_ID=                           # numeric app ID from GitHub App settings
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
                                         # paste as single line with literal \n between lines
GITHUB_APP_NAME=                         # slug name of your GitHub App

# ── LangGraph / Web URLs ──────────────────────────────────────────────────────
LANGGRAPH_API_URL=http://localhost:2024  # where the LangGraph server listens
NEXT_PUBLIC_API_URL=http://localhost:3000/api  # web app API base URL

# ── Local Mode (use instead of GitHub App auth for local dev) ─────────────────
# OPEN_SWE_LOCAL_MODE=true

# ── CLI (only needed when running apps/cli) ───────────────────────────────────
# OPEN_SWE_LOCAL_PROJECT_PATH=/absolute/path/to/your/git/repo

# ── API Bearer Token Auth (optional alternative auth) ────────────────────────
# API_BEARER_TOKEN=some-secret-token
# API_BEARER_TOKENS=token1,token2,token3

# ── V2 / External APIs (only needed for apps/open-swe-v2 features) ────────────
# ANTHROPIC_API_KEY=sk-ant-...           # required for V2 command-safety check
# TAVILY_API_KEY=tvly-...                # required for V2 web search tool

# ── Daytona Sandbox (required for Programmer node sandbox execution) ───────────
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=https://app.daytona.io

# ── LangSmith Tracing (optional but recommended) ──────────────────────────────
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=open-swe-local

